{
  "id": "esp32-s3",
  "name": "ESP32-S3",
  "packageName": "QFN-56",
  "voltage": "3.0V - 3.6V",
  "notes": "For data logging with BLE/WiFi and native USB.",
  "protocols": ["SPI", "I2C", "UART", "USB", "GPIO"],
  "interfaces": [
    {
      "name": "SPI2",
      "protocol": "SPI",
      "signalPins": [
        { "signal": "SCK", "pins": ["GPIO12"] },
        { "signal": "MISO", "pins": ["GPIO13"] },
        { "signal": "MOSI", "pins": ["GPIO11"] }
      ]
    },
    {
      "name": "I2C0",
      "protocol": "I2C",
      "signalPins": [
        { "signal": "SCL", "pins": ["GPIO6"] },
        { "signal": "SDA", "pins": ["GPIO7"] }
      ]
    },
    {
      "name": "I2C1",
      "protocol": "I2C",
      "signalPins": [
        { "signal": "SCL", "pins": ["GPIO8"] },
        { "signal": "SDA", "pins": ["GPIO9"] }
      ]
    },
    {
      "name": "UART1",
      "protocol": "UART",
      "signalPins": [
        { "signal": "TX", "pins": ["GPIO17"] },
        { "signal": "RX", "pins": ["GPIO18"] }
      ]
    },
    {
      "name": "UART2",
      "protocol": "UART",
      "signalPins": [
        { "signal": "TX", "pins": ["GPIO4"] },
        { "signal": "RX", "pins": ["GPIO5"] }
      ]
    },
    {
      "name": "USB_OTG",
      "protocol": "USB",
      "signalPins": [
        { "signal": "D+", "pins": ["GPIO20"] },
        { "signal": "D-", "pins": ["GPIO19"] }
      ]
    }
  ],
  "gpioPins": [
    "GPIO1",
    "GPIO2",
    "GPIO4",
    "GPIO5",
    "GPIO6",
    "GPIO7",
    "GPIO8",
    "GPIO9",
    "GPIO10",
    "GPIO11",
    "GPIO12",
    "GPIO13",
    "GPIO14",
    "GPIO15",
    "GPIO16",
    "GPIO17",
    "GPIO18",
    "GPIO21",
    "GPIO38",
    "GPIO47",
    "GPIO48"
  ]
}
