{
  "id": "stm32g0b1cb",
  "name": "STM32G0B1CB",
  "packageName": "LQFP-48",
  "voltage": "1.7V - 3.6V",
  "notes": "Compact STM32G0 option with USB and mixed serial interfaces.",
  "protocols": ["SPI", "I2C", "UART", "USB", "SWD", "GPIO"],
  "interfaces": [
    {
      "name": "SPI1",
      "protocol": "SPI",
