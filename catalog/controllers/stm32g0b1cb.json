      "protocol": "UART",
      "signalPins": [
        { "signal": "TX", "pins": ["PA2"] },
        { "signal": "RX", "pins": ["PA3"] }
      ]
    },
    {
      "name": "USB_FS",
      "protocol": "USB",
      "signalPins": [
        { "signal": "D+", "pins": ["PA12"] },
        { "signal": "D-", "pins": ["PA11"] }
      ]
    },
    {
      "name": "SWD",
      "protocol": "SWD",
      "signalPins": [
        { "signal": "SWDIO", "pins": ["PA13"] },
        { "signal": "SWCLK", "pins": ["PA14"] }
